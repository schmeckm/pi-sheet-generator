    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "morgan": "^1.10.0",
    "mqtt": "^5.15.1",
    "multer": "^1.4.5-lts.1",
    "node-opcua": "^2.173.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.16.0",
