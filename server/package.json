  "private": true,
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "dev": "node --watch --watch-path=./index.js --watch-path=./routes --watch-path=./services --watch-path=./middleware --watch-path=./websocket index.js",
    "start": "node index.js",
    "db:sync": "node scripts/db-sync.js",
