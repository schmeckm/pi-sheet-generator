{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CanonicalXStep",
  "type": "object",
  "required": ["id", "name", "stepType"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "stepType": { "type": "string" },
    "processArea": { "type": "string" },
    "packagingType": { "type": "string" },
    "category": { "type": "string" },
    "gmpRelevant": { "type": "boolean" },
    "requiresSignature": { "type": "boolean" },
    "keywords": { "type": "array", "items": { "type": "string" } },
    "parameters": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "value": { "type": "string" },
          "unit": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": true
}
