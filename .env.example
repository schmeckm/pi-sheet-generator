# Local development — copy: cp .env.example .env
# Runtime settings (prompts, SAP URL in UI) live in Admin → Settings (DB), not here.

# --- Database (PostgreSQL + pgvector via docker compose) ---
# Host port 7003 → container 5432
DATABASE_URL=postgres://pisheet:pisheet_dev@localhost:7003/pisheet
# DB_SSL=true   # managed Postgres with SSL only

# --- API keys (chat / PI generation: set provider per task in Admin → Settings) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional: Admin API key for org usage stats in Admin → Settings (not prepaid balance)
# ANTHROPIC_ADMIN_API_KEY=

# --- JWT authentication ---
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# --- Embeddings (optional — semantic XStep / knowledge RAG; falls back to keyword search) ---
OPENAI_API_KEY=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_URL=https://api.openai.com/v1/embeddings

# --- Server ---
# Port scheme (host ports ≥ 7000):
#   7000 = API   7001 = SAP MCP   7002 = Vite UI   7003 = PostgreSQL   7004 = Docker nginx UI
PORT=7000
NODE_ENV=development
# CORS_ORIGINS=http://localhost:7002,http://127.0.0.1:7002

# --- SAP MCP (optional live equipment; Admin settings override URL when set) ---
# Local: cd ../sap-mcp-server && PORT=7001 npm start
SAP_MCP_ENABLED=false
SAP_MCP_URL=http://localhost:7001/sse
# SAP_MCP_AUTH_TOKEN=

# --- Frontend (Vite dev server) ---
VITE_DEV_PORT=7002
# /api — Vite proxies to PORT (7000)
VITE_API_URL=/api

# --- XStep Agent MVP (isolated module, disabled by default) ---
# XSTEP_AGENT_ENABLED=false
# XSTEP_AGENT_LLM_PROVIDER=mock
# XSTEP_AGENT_OLLAMA_URL=http://localhost:11434
# XSTEP_AGENT_OLLAMA_MODEL=llama3.2
# XSTEP_AGENT_OPENAI_MODEL=gpt-4o-mini
