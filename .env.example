# Database (PostgreSQL + pgvector via docker compose)
# Host port 7003 → container 5432
DATABASE_URL=postgres://pisheet:pisheet_dev@localhost:7003/pisheet

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# JWT authentication
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Embeddings (OpenAI text-embedding-3-small or compatible, optional)
OPENAI_API_KEY=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Port scheme (all host ports ≥ 7000):
#   7000 = API   7001 = SAP MCP   7002 = Vite UI   7003 = PostgreSQL   7004 = Docker nginx UI
PORT=7000
NODE_ENV=development

# SAP MCP (docker: host 7001; local: cd ../sap-mcp-server && PORT=7001 npm start)
SAP_MCP_ENABLED=false
SAP_MCP_URL=http://localhost:7001/sse

# Frontend (Vite dev server)
VITE_DEV_PORT=7002
# Use /api in dev — Vite proxies to PORT (7000)
VITE_API_URL=/api
