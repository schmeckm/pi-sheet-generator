# Portainer stack environment — copy values into Portainer "Environment variables"
# or upload as env file when creating the stack.

# Docker Hub namespace (must match published images)
DOCKERHUB_USER=schmeckm
IMAGE_TAG=latest

# Host port for the web UI (nginx → proxies /api to internal api service)
CLIENT_PORT=7004

# Database
POSTGRES_DB=pisheet
POSTGRES_USER=pisheet
POSTGRES_PASSWORD=change-me-strong-db-password

# API (required)
JWT_SECRET=change-me-min-32-characters-random-secret
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional embeddings
EMBEDDING_API_KEY=
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# CORS — add your Portainer host URL, e.g. http://192.168.1.10:7004
CORS_ORIGINS=http://localhost:7004,http://127.0.0.1:7004

# First deploy: seed demo users and XSteps (set false after first successful start)
AUTO_SEED=true

# SAP MCP (optional — requires reachable HTTPS URL for Claude, not plain Docker internal URL)
SAP_MCP_ENABLED=false
SAP_MCP_URL=
SAP_MCP_AUTH_TOKEN=
