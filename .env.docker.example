# Copy to .env for docker compose (or pass via shell)
# cp .env.docker.example .env

JWT_SECRET=change-me-to-a-long-random-secret
ANTHROPIC_API_KEY=sk-ant-your-key-here
EMBEDDING_API_KEY=
OPENAI_API_KEY=

# First start: seed users + XSteps
AUTO_SEED=true

# SAP MCP — Claude API must reach this URL from the internet (HTTPS).
# Internal Docker URL does NOT work for Anthropic MCP connector.
# Local pilot: leave disabled, or use ngrok/cloudflare tunnel:
# SAP_MCP_ENABLED=true
# SAP_MCP_URL=https://your-tunnel.example.com/sse
SAP_MCP_ENABLED=false
