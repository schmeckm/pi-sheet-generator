# Docker Compose (profile full) — copy: cp .env.docker.example .env
# DATABASE_URL and CORS_ORIGINS are set in docker-compose.yml; override here only if needed.

JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Embeddings (optional)
OPENAI_API_KEY=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# First start: seed demo users + XSteps (set false after first successful run)
AUTO_SEED=true

# SAP MCP — Claude must reach a public HTTPS URL (not internal Docker hostnames).
# Local pilot: leave disabled, or expose via ngrok/cloudflare tunnel:
# SAP_MCP_ENABLED=true
# SAP_MCP_URL=https://your-tunnel.example.com/sse
SAP_MCP_ENABLED=false
# SAP_MCP_URL=          # compose default: http://sap-mcp:3001/sse when enabled
# SAP_MCP_AUTH_TOKEN=
